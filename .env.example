# Fair Line — environment variables for the Python data pipeline.
# Copy this file to ".env" (same folder) and fill in your own values.
# The .env file is git-ignored and never shared (see package_project.py).

# football-data.org free API key (World Cup + club fixtures)
FOOTBALL_DATA_KEY=your_football_data_key

# The Odds API key (live bookmaker odds; free tier = 500 credits/month)
ODDS_API_KEY=your_odds_api_key

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase SECRET key (service role / sb_secret_...). Server-side only —
# it bypasses Row-Level Security. NEVER put this in the frontend.
SUPABASE_SERVICE_KEY=your_supabase_service_key
